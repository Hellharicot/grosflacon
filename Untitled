CREATE FUNCTION check_vintage_year() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
	IF NEW.vintage > EXTRACT(YEAR FROM CURRENT_DATE) THEN
		RAISE EXCEPTION 'Vintage (%) cannot reference to the future', NEW.vintage;
	END IF;
	RETURN NEW;
END;
$$;

CREATE TABLE account (
    id INTEGER NOT NULL PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
    email character varying(255) NOT NULL UNIQUE,
    password_hash text NOT NULL,
    role_id integer NOT NULL REFERENCES role(id) ON DELETE RESTRICT,
    created_at timestamp with time zone DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE appellation (
    id INTEGER NOT NULL PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
    region_id integer NOT NULL REFERENCES region(id) ON DELETE RESTRICT,
    name text NOT NULL UNIQUE
);

CREATE TABLE aroma (
    id INTEGER NOT NULL PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
    name character varying(50) NOT NULL UNIQUE,
    aroma_subfamily_id integer NOT NULL REFERENCES aroma_subfamily(id) ON DELETE RESTRICT
);

CREATE TABLE aroma_family (
    id INTEGER NOT NULL PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
    name character varying(50) NOT NULL UNIQUE
);


CREATE TABLE aroma_subfamily (
    id INTEGER NOT NULL PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
    name character varying(50) NOT NULL UNIQUE,
    aroma_family_id integer NOT NULL REFERENCES aroma_family(id) ON DELETE RESTRICT
);

CREATE TABLE color (
    id INTEGER NOT NULL PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
    name character varying(50) NOT NULL UNIQUE
);

CREATE TABLE country (
    id INTEGER NOT NULL PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
    name character varying(100) NOT NULL UNIQUE
);

CREATE TABLE form_fields (
    id INTEGER NOT NULL PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
    label character varying(100) NOT NULL,
    slug character varying(50) NOT NULL UNIQUE,
    input_type_id integer NOT NULL REFERENCES input_type(id) ON DELETE RESTRICT,
    display_order integer NOT NULL UNIQUE,
    form_step_id integer NOT NULL REFERENCES form_step(id) ON DELETE RESTRICT,
    reference_table character varying(50)
);

CREATE TABLE form_step (
    id INTEGER NOT NULL PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
    name character varying(50) NOT NULL UNIQUE,
    description text,
    slug character varying(50) NOT NULL UNIQUE,
    display_order integer NOT NULL UNIQUE
);


CREATE TABLE input_type (
    id INTEGER NOT NULL PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
    name character varying(50) NOT NULL UNIQUE
);

CREATE TABLE region (
    id INTEGER NOT NULL PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
    name text NOT NULL,
    country_id integer NOT NULL REFERENCES country(id) ON DELETE RESTRICT
);

CREATE TABLE wine (
    id INTEGER NOT NULL PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
    appellation_id integer NOT NULL REFERENCES appellation(id) ON DELETE RESTRICT,
    producer character varying(255) NOT NULL,
    cuvee character varying(255),
    color_id integer NOT NULL REFERENCES color(id) ON DELETE RESTRICT,
    vintage integer,
    CONSTRAINT check_vintage_history CHECK ((vintage >= 1700))
);

CREATE INDEX idx_account_role_id ON account USING btree (role_id);

CREATE INDEX idx_appellation_region_id ON appellation USING btree (region_id);

CREATE INDEX idx_aroma_aroma_subfamily_id ON aroma USING btree (aroma_subfamily_id);

CREATE INDEX idx_aroma_subfamily_aroma_family_id ON aroma_subfamily USING btree (aroma_family_id);

CREATE INDEX idx_region_country_id ON region USING btree (country_id);

CREATE INDEX idx_wine_appellation_id ON wine USING btree (appellation_id);

CREATE INDEX idx_wine_color_id ON wine USING btree (color_id);

CREATE TRIGGER trigger_check_vintage BEFORE INSERT OR UPDATE ON wine FOR EACH ROW EXECUTE FUNCTION public.check_vintage_year();


